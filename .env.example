# ===========================================
# ENVIRONMENT VARIABLES FOR STB (SabkaTechBazar)
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ===========================================
# DATABASE
# ===========================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# FIREBASE (Google Sign-In)
# ===========================================
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Google Web Client ID (for Median.co native Google Sign-In)
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# ===========================================
# RAZORPAY PAYMENTS
# ===========================================
# Get these from https://dashboard.razorpay.com/app/keys
# Test keys start with rzp_test_, live keys start with rzp_live_
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ===========================================
# IMAGE STORAGE (ImageKit)
# ===========================================
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-id
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxx

# ===========================================
# BLOB STORAGE (Vercel Blob)
# ===========================================
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ===========================================
# PUSH NOTIFICATIONS (OneSignal)
# ===========================================
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_REST_API_KEY=os_v2_app_xxxxxxxxxxxx

# ===========================================
# EMAIL (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com
COMPANY_EMAIL=admin@yourdomain.com

# ===========================================
# BUSINESS GST (India)
# ===========================================
BUSINESS_GSTIN=29XXXXXXXXXXXZX
BUSINESS_STATE_CODE=29
